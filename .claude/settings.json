{
  "permissions": {
    "allow": [
      "Bash(bash ~/.claude/agent-crew/ship-check.sh *)",
      "Bash(bash ~/.claude/agent-crew/ship-init.sh *)",
      "Bash(bash ~/.claude/agent-crew/ship-cancel.sh *)",
      "Bash(bash ~/.claude/agent-crew/crew-daemon.sh *)",
      "Bash(./gradlew test *)",
      "Bash(npx tsc *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-rules.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-dangerous-commands.sh"
          }
        ]
      }
    ]
  }
}
